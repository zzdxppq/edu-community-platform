# ============================================
# 河南城乡学校共同体发展平台 - 环境变量配置
# ============================================
# 使用方法: 复制本文件为 .env，按需修改
#   cp .env.example .env
# ============================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=root123
MYSQL_PORT=3306

# ---- Redis ----
REDIS_PORT=6379

# ---- Nacos ----
NACOS_PORT=8848

# ---- Gateway ----
GATEWAY_PORT=8080

# ---- Core Service ----
CORE_SERVICE_PORT=8081

# ---- Content Service ----
CONTENT_SERVICE_PORT=8082

# ---- File Service ----
FILE_SERVICE_PORT=8083

# ---- Portal (Nuxt 3 SSR) ----
PORTAL_PORT=3000

# ---- Admin (Vue 3 SPA) ----
ADMIN_PORT=3001
